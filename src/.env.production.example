# .env.production.example - Production Environment Template
# Copy to .env and configure for production

# ============================================================================
# PRIMARY API KEYS
# ============================================================================

# Primary Gemini API Key (REQUIRED)
GOOGLE_API_KEY=your_primary_gemini_api_key

# ============================================================================
# BACKUP API KEYS (Recommended for Production)
# ============================================================================

# Backup API Keys for automatic rotation and failover
GOOGLE_API_KEY_BACKUP_1=backup_key_1
GOOGLE_API_KEY_BACKUP_2=backup_key_2
GOOGLE_API_KEY_BACKUP_3=backup_key_3
GOOGLE_API_KEY_BACKUP_4=backup_key_4
GOOGLE_API_KEY_BACKUP_5=backup_key_5

# ============================================================================
# DATABASE
# ============================================================================

# MongoDB Connection (Production)
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/rag_production

# ============================================================================
# REDIS CACHE (Recommended for Production)
# ============================================================================

# Redis URL for distributed caching
REDIS_URL=redis://localhost:6379/0
# Or Redis Cloud: redis://username:password@host:port/0

# ============================================================================
# RELIABILITY CONFIGURATION
# ============================================================================

# Retry Strategy
MAX_RETRY_ATTEMPTS=3
INITIAL_RETRY_DELAY=1.0
MAX_RETRY_DELAY=60.0

# Timeouts (seconds)
TRANSLATION_TIMEOUT=30
RETRIEVAL_TIMEOUT=10
GENERATION_TIMEOUT=60
TOTAL_REQUEST_TIMEOUT=180

# Circuit Breaker
CIRCUIT_BREAKER_THRESHOLD=5
CIRCUIT_BREAKER_TIMEOUT=60

# ============================================================================
# RATE LIMITING
# ============================================================================

# Gemini Flash Limits
GEMINI_FLASH_RPM=15
GEMINI_FLASH_RPD=1500

# Gemini Pro Limits
GEMINI_PRO_RPM=2
GEMINI_PRO_RPD=50

# Translation Limits
TRANSLATION_RPM=10

# ============================================================================
# CACHING
# ============================================================================

# Cache TTL (seconds)
TRANSLATION_CACHE_TTL=86400  # 24 hours
EMBEDDING_CACHE_TTL=604800   # 7 days
RESPONSE_CACHE_TTL=3600      # 1 hour

# Memory Cache Size
MEMORY_CACHE_SIZE=1000

# ============================================================================
# MONITORING & ALERTING
# ============================================================================

# Enable Monitoring
ENABLE_MONITORING=true

# Monitoring Configuration
MAX_TRACES=1000
SLOW_REQUEST_THRESHOLD=10.0

# Alert Thresholds
ERROR_RATE_THRESHOLD=0.1
QUOTA_WARNING_THRESHOLD=0.9

# ============================================================================
# GRACEFUL DEGRADATION
# ============================================================================

# Fallback Features
ENABLE_FALLBACK=true
ENABLE_SEARCH_ONLY_MODE=true
ENABLE_CACHED_RESPONSES=true

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret (Generate: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=your_production_jwt_secret_minimum_32_chars

# Session Secret
SESSION_SECRET=your_production_session_secret

# ============================================================================
# APPLICATION
# ============================================================================

# Environment
ENVIRONMENT=production

# Debug Mode (MUST be false in production)
DEBUG=false

# Log Level
LOG_LEVEL=INFO

# ============================================================================
# CORS
# ============================================================================

# Allowed Origins (your frontend URLs)
ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================================================
# OPTIONAL: EXTERNAL SERVICES
# ============================================================================

# Sentry (Error Tracking)
# SENTRY_DSN=your_sentry_dsn

# Email Alerts
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=alerts@yourdomain.com
# SMTP_PASSWORD=your_app_password

# Slack Webhooks (for alerts)
# SLACK_WEBHOOK_URL=your_slack_webhook_url

# ============================================================================
# PRODUCTION CHECKLIST
# ============================================================================

# [ ] All API keys configured
# [ ] Backup API keys added
# [ ] Redis configured and tested
# [ ] MongoDB production cluster ready
# [ ] Monitoring enabled
# [ ] Alerting configured
# [ ] DEBUG=false
# [ ] Strong secrets generated
# [ ] CORS origins restricted
# [ ] Rate limits configured
# [ ] Backup strategy in place
# [ ] SSL/TLS certificates ready
# [ ] Load balancer configured
# [ ] Auto-scaling rules set
# [ ] Disaster recovery plan documented

# ============================================================================
# NOTES
# ============================================================================

# 1. NEVER commit this file with real values to version control
# 2. Use environment-specific secrets management (AWS Secrets Manager, etc.)
# 3. Rotate all secrets regularly (every 90 days minimum)
# 4. Monitor quota usage daily
# 5. Set up alerts for critical errors
# 6. Test failover scenarios regularly
# 7. Keep backup API keys in separate Google Cloud projects
# 8. Document all configuration changes
# 9. Review security settings monthly
# 10. Maintain separate configs for staging and production
