# .env.example - Environment Variables Template
# Copy this file to .env and fill in your values

# ============================================================================
# API KEYS
# ============================================================================

# Google Gemini API Key (Required)
GOOGLE_API_KEY=your_gemini_api_key_here

# ============================================================================
# DATABASE
# ============================================================================

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/

# MongoDB Database Name
MONGODB_DB=rag_system

# ============================================================================
# SECURITY
# ============================================================================

# JWT Secret Key (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=your_jwt_secret_key_here_minimum_32_characters

# Encryption Key (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_encryption_key_here

# Session Secret (Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SESSION_SECRET=your_session_secret_here

# ============================================================================
# RATE LIMITING
# ============================================================================

# Rate Limits
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000

# ============================================================================
# APPLICATION
# ============================================================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug Mode (true/false)
DEBUG=false

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ============================================================================
# SECURITY SETTINGS
# ============================================================================

# Maximum Login Attempts
MAX_LOGIN_ATTEMPTS=5

# Account Lockout Duration (minutes)
LOCKOUT_DURATION_MINUTES=30

# Session Timeout (hours)
SESSION_TIMEOUT_HOURS=24

# Password Minimum Length
PASSWORD_MIN_LENGTH=8

# ============================================================================
# CORS (if using API)
# ============================================================================

# Allowed Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:8502

# ============================================================================
# FILE UPLOAD
# ============================================================================

# Maximum File Size (MB)
MAX_FILE_SIZE_MB=10

# Allowed File Extensions (comma-separated)
ALLOWED_EXTENSIONS=.pdf,.txt,.docx

# ============================================================================
# REDIS (Optional - for production rate limiting)
# ============================================================================

# Redis URL
# REDIS_URL=redis://localhost:6379/0

# ============================================================================
# EMAIL (Optional - for alerts)
# ============================================================================

# SMTP Settings
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your_email@gmail.com
# SMTP_PASSWORD=your_app_password
# SMTP_FROM=noreply@yourdomain.com

# ============================================================================
# MONITORING (Optional)
# ============================================================================

# Sentry DSN (for error tracking)
# SENTRY_DSN=your_sentry_dsn_here

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit .env file to version control
# 2. Use strong, unique values for all secrets
# 3. Rotate secrets regularly
# 4. Use different values for development/staging/production
# 5. Store production secrets in secure vault (AWS Secrets Manager, Azure Key Vault, etc.)
