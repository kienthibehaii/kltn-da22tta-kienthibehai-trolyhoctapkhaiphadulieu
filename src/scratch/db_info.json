            "id": 4,
            "type": "multiple_choice",
            "difficulty": "medium",
            "question": "Bước nào là bước đầu tiên trong thuật toán Apriori?",
            "options": {
              "A": "Tạo tất cả các luật kết hợp",
              "B": "Tính toán Lift của các tập mục",
